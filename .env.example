# Environment variables for kd-yogurt-core-db CLI tools (migrations, seeds)
# Copy this file to .env and fill in your local values.

DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_NAME=yogurt_db

# SSL — set to true if your local MySQL instance requires SSL
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

NODE_ENV=development
